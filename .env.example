# UI theme preference: true for dark, false for light
APP_DARK_MODE=true
# Disable cursor control functionality (hides Stop button)
APP_DISABLE_CURSOR_CONTROL=true
# Enable auto-stop mode (bypasses UI and automatically focuses cursor and stops)
APP_AUTO_STOP=false
# Delay in seconds before sending stop signal (allows Cursor to start streaming first)
# Recommended: 0.5-2.0 seconds. Set to 0 to disable delay.
APP_STOP_DELAY=2

# Google Gemini API key for AI improvements
GEMINI_API_KEY=your_key_here #required

# Memory RAG system configuration

MEMORY_RAG_TOP_K=5 # This determines how many top results are returned from the semantic search

# Embedding cache configuration
EMBEDDING_CACHE_ENABLED=true # Enable/disable persistent embedding cache (true/false)
EMBEDDING_CACHE_MAX_ENTRIES=10000 # Maximum number of embeddings to cache (default: 10000, ~50-100MB)
EMBEDDING_CACHE_TTL_DAYS=30 # Cache entries expire after N days (default: 30)

# Embedding provider configuration - choose between "gemini" or "openai"
EMBEDDING_PROVIDER=gemini
# Google Gemini embedding configuration (free tier available)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI embedding configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small